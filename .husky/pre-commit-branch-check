#!/usr/bin/env sh
# Branch protection hook - prevents commits directly to main/master

# Get current branch
current_branch=$(git rev-parse --abbrev-ref HEAD)

# Protected branches
protected_branches="main master"

# Check if current branch is protected
for protected in $protected_branches; do
  if [ "$current_branch" = "$protected" ]; then
    echo ""
    echo "🚫 ERROR: Direct commits to '$current_branch' branch are not allowed!"
    echo ""
    echo "To fix this:"
    echo "1. Create a new branch: git checkout -b feature/your-feature-name"
    echo "2. Or switch to existing branch: git checkout your-branch-name"
    echo "3. Make your changes and commit"
    echo "4. Push your branch: git push origin your-branch-name"
    echo "5. Create a Pull Request on GitHub"
    echo ""
    echo "💡 Tip: Use 'git stash' to save your current changes before switching branches"
    echo ""
    exit 1
  fi
done

echo "✅ Branch check passed: Working on '$current_branch' branch"
